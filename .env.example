## Copy this file to `.env.local` for development (never commit real keys)
MISTRAL_API_KEY=PASTE_API_KEY_DI_SINI

## Optional: override model
## Tip: for long-term stability, prefer pinning a fixed model name (not "*-latest")
## Example: mistral-small-latest
MISTRAL_MODEL=mistral-small-latest

## Safety / cost controls
## Max input text length (server-side hard limit)
MAX_TEXT_CHARS=10000

## Max input text length (client-side textarea limit)
NEXT_PUBLIC_MAX_TEXT_CHARS=10000

## Basic rate limiting (best-effort, in-memory)
## max requests per window per IP
RATE_LIMIT_MAX=30
## window length in seconds
RATE_LIMIT_WINDOW_SEC=60

## Best-effort server cache (makes repeated checks for same input more consistent)
## NOTE: in serverless environments this cache may reset between cold starts.
ENABLE_SERVER_CACHE=true
## cache TTL in seconds
CACHE_TTL_SEC=3600
## max cached entries
CACHE_MAX_ENTRIES=500
